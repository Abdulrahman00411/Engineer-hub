generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  role             String // 'freelancer' or 'client'
  name             String
  email            String   @unique
  password         String
  phone            String   @default("")
  location         String   @default("")
  engineeringField String   @default("")
  hourlyRate       Float    @default(0)
  avatar           Json? // { initials, bg, color }
  rating           Float    @default(0)
  reviews          Int      @default(0)
  projects         Int      @default(0)
  badge            String   @default("New")
  badgeType        String   @default("gray")
  available        Boolean  @default(true)
  verified         Boolean  @default(false)
  joinedDate       String   @default("")
  bio              String   @default("")
  skills           String[] @default([])
  services         String[] @default([])
  education        Json[]   @default([]) // [{ degree, institute, year, grade }]
  portfolio        Json[]   @default([]) // [{ title, desc, year, value }]
  reviewsList      Json[]   @default([]) // [{ client, rating, comment, date }]
  completedJobs    Int      @default(0)
  totalEarned      String   @default("$0")
  postedJobs       Int      @default(0)
  totalSpent       String   @default("$0")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  jobsPosted       Job[]          @relation("ClientJobs")
  gigs             Gig[]
  bids             Bid[]
  ordersAsEngineer Order[]        @relation("EngineerOrders")
  ordersAsClient   Order[]        @relation("ClientOrders")
  sentMessages     Message[]      @relation("SenderMessages")
  receivedMessages Message[]      @relation("ReceiverMessages")
  conversations    Conversation[] @relation("ParticipantConversations")
}

model Job {
  id          String   @id @default(cuid())
  clientId    String
  clientName  String
  title       String
  category    String
  type        String   @default("Fixed Price") // 'Fixed Price' or 'Hourly'
  budget      String   @default("")
  budgetMin   Float    @default(0)
  budgetMax   Float    @default(0)
  hourlyRate  Float    @default(0)
  level       String   @default("Intermediate")
  location    String   @default("")
  tags        String[] @default([])
  description String   @default("")
  deadline    String   @default("")
  urgent      Boolean  @default(false)
  posted      String   @default("")
  bidsCount   Int      @default(0)
  status      String   @default("open") // 'open', 'in-progress', 'completed', 'cancelled'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  client User  @relation("ClientJobs", fields: [clientId], references: [id])
  bid    Bid[]
}

model Gig {
  id           String   @id @default(cuid())
  engineerId   String
  engineerName String
  initials     String   @default("")
  avatar       Json? // { initials, bg, color }
  title        String
  category     String
  icon         String   @default("")
  accent       String   @default("#2563EB")
  startingAt   Float    @default(0)
  deliveryDays Int      @default(7)
  rating       Float    @default(0)
  reviews      Int      @default(0)
  description  String   @default("")
  tags         String[] @default([])
  packages     Json[]   @default([]) // [{ name, price, delivery, desc }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  engineer User    @relation(fields: [engineerId], references: [id])
  orders   Order[]
}

model Bid {
  id           String   @id @default(cuid())
  jobId        String
  engineerId   String
  engineerName String
  amount       Float
  duration     Int      @default(0)
  cover        String   @default("")
  status       String   @default("pending") // 'pending', 'accepted', 'rejected'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  job      Job  @relation(fields: [jobId], references: [id])
  engineer User @relation(fields: [engineerId], references: [id])
}

model Order {
  id           String   @id @default(cuid())
  clientId     String
  engineerId   String
  gigId        String
  engineerName String
  clientName   String
  gigTitle     String
  package      Json? // { name, price, delivery, desc }
  amount       Float
  status       String   @default("pending") // 'pending', 'accepted', 'in-progress', 'delivered', 'completed', 'cancelled'
  timeline     Json? // { acceptedAt, startedAt, deliveredAt, completedAt }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  client   User @relation("ClientOrders", fields: [clientId], references: [id])
  engineer User @relation("EngineerOrders", fields: [engineerId], references: [id])
  gig      Gig  @relation(fields: [gigId], references: [id])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  receiverId     String
  text           String
  time           String   @default("")
  date           String   @default("Today")
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  sender   User @relation("SenderMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceiverMessages", fields: [receiverId], references: [id])
}

model Conversation {
  id               String   @id @default(cuid())
  participants     String[] // User IDs
  engineerName     String   @default("")
  engineerInitials String   @default("")
  clientName       String   @default("")
  lastMsg          String   @default("")
  lastTime         String   @default("")
  unread           Json? // Map<String, Number>
  messages         Json[]   @default([]) // [{ id, from, text, time, date }]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  participantsRelation User[] @relation("ParticipantConversations")
}
